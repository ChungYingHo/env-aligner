{
  "name": "env-aligner",
  "version": "3.0.0",
  "description": "A CLI tool to initialize, check, and fix .env files against a schema (e.g. .env.example).",
  "keywords": [
    ".env",
    ".env.example",
    "environment variables",
    "check",
    "init",
    "fix"
  ],
  "homepage": "https://github.com/ChungYingHo/env-aligner",
  "bugs": {
    "url": "https://github.com/ChungYingHo/env-aligner/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ChungYingHo/env-aligner.git"
  },
  "author": {
    "name": "Jeremy Ho",
    "email": "ag.cyho@gmail.com",
    "url": "https://jeremyho.tw/"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "env-aligner": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint-config-jeremy": "^1.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
